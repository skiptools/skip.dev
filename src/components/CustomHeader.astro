---
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from './SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from './ThemeSelect.astro';

const curLocale = Astro.locals.starlightRoute.locale;
const slug = Astro.locals.starlightRoute.entry.slug;

const showBanner = (Astro.locals.starlightRoute.entry.data as any).showBanner !== false;
const bannerMessage = (Astro.locals.t as (key: string) => string)('banner.message');
const hasBanner = showBanner && bannerMessage;

type Link = {
  title: string;
  value: string;
  transfer: boolean;
};

// Note that these links are duplicated in SiteTitle.astro and CustomHeader.astro
const links: Link[] = [
  {
    title: Astro.locals.t('header.link.docs'),
    value: '/docs/',
    transfer: true,
  },
  {
    title: Astro.locals.t('header.link.blog'),
    value: '/blog/',
    transfer: false,
  },
  {
    title: Astro.locals.t('header.link.sponsor'),
    value: '/sponsor/',
    transfer: true,
  },
];
---
{hasBanner && (
  <div class="site-banner" role="status" data-banner hidden>
    <span class="banner-text" set:html={bannerMessage} />
    <button class="banner-close" type="button" aria-label="Dismiss banner">
      <svg width="10" height="10" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1.5 1.5L12.5 12.5M12.5 1.5L1.5 12.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
)}
<script is:inline>
  (function() {
    var banner = document.querySelector('[data-banner]');
    if (!banner) return;
    var key = 'banner-dismissed-at';
    var ts = localStorage.getItem(key);
    if (ts && Date.now() - Number(ts) < 30 * 86400000) {
      banner.remove();
      return;
    }
    localStorage.removeItem(key);
    document.body.prepend(banner);
    banner.removeAttribute('hidden');
    banner.querySelector('.banner-close').addEventListener('click', function() {
      localStorage.setItem(key, String(Date.now()));
      banner.remove();
    });
  })();
</script>
<div class="header sl-flex">
  <div class="full-width sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex">
    <Search />
  </div>
  <div class="sl-hidden md:sl-flex right-group">
    <div class="desktop">
      {
        links.map((link) => (
          <a href={link.transfer && curLocale ? `/${curLocale}${link.value}` : link.value}>
            {link.title}
          </a>
        ))
      }
    </div>
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <LanguageSelect />
    <ThemeSelect />
  </div>
</div>

<style>
  /* ── Site-wide announcement banner ── */
  /* JS moves the banner to <body> so it's independent of the header. */
  .site-banner {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--sl-banner-height);
    padding: 0 2.5rem 0 1rem;
    background: linear-gradient(90deg, hsl(38, 65%, 20%), hsl(28, 60%, 23%));
    border-bottom: 1px solid hsl(38, 50%, 30%);
    font-size: var(--sl-text-sm);
    line-height: 1.4;
    text-align: center;
    color: hsl(40, 55%, 88%);
  }
  .banner-text {
    display: inline;
  }
  .banner-close {
    position: absolute;
    inset-inline-end: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    background: hsla(0, 0%, 100%, 0.1);
    border: 1px solid hsla(0, 0%, 100%, 0.15);
    border-radius: 0.25rem;
    color: hsl(40, 40%, 75%);
    cursor: pointer;
    padding: 0;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .banner-close:hover {
    background: hsla(0, 0%, 100%, 0.2);
    border-color: hsla(0, 0%, 100%, 0.3);
    color: hsl(40, 55%, 95%);
  }
  :root[data-theme='light'] .banner-close {
    background: hsla(30, 50%, 30%, 0.08);
    border-color: hsla(30, 50%, 30%, 0.2);
    color: hsl(30, 40%, 40%);
  }
  :root[data-theme='light'] .banner-close:hover {
    background: hsla(30, 50%, 30%, 0.15);
    border-color: hsla(30, 50%, 30%, 0.35);
    color: hsl(30, 45%, 25%);
  }
  .banner-text :global(a) {
    color: hsl(40, 100%, 72%);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .banner-text :global(a:hover) {
    color: hsl(40, 100%, 85%);
  }
  :root[data-theme='light'] .site-banner {
    background: linear-gradient(90deg, hsl(40, 80%, 92%), hsl(35, 75%, 88%));
    border-bottom-color: hsl(38, 55%, 80%);
    color: hsl(30, 45%, 22%);
  }
  :root[data-theme='light'] .banner-text :global(a) {
    color: hsl(25, 85%, 38%);
  }
  :root[data-theme='light'] .banner-text :global(a:hover) {
    color: hsl(25, 90%, 30%);
  }

  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }
  .full-width {
    width: 100%;
  }
  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }
  .desktop,
  .release-link::after,
  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .header {
      --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
      --__main-column-fr: calc(
        (
            100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
              (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
              var(--sl-content-width)
          ) / 2
      );
      display: grid;
      grid-template-columns:
        /* 1 (site title): runs up until the main content column's left edge or the width of the title, whichever is the largest  */
        minmax(
          calc(var(--__sidebar-pad, 0rem)),
          auto
        )
        /* 2 (search box): all free space that is available. */
        1fr
        /* 3 (right items): use the space that these need. */
        auto;
      align-content: center;
    }
  }
  a:hover {
    color: var(--sl-color-gray-2);
  }
  :root[data-theme='light'] {
    .header a:hover {
      color: var(--sl-color-gray-3);
    }
  }
</style>
<style is:global>
  .header {
    border: none !important;
  }
body[data-mobile-menu-expanded] header {
  background-color: var(--sl-color-bg);
}

/* ── Site-wide banner offset ──
   JS moves the banner to <body>, so it's a direct child of body.
   When it exists, push the header and all content down by --sl-banner-height. */
:root {
  --sl-banner-height: 0rem;
}
body:has(> .site-banner) {
  --sl-banner-height: 2rem;
}
body:has(> .site-banner) header {
  top: var(--sl-banner-height) !important;
}
body:has(> .site-banner) .sidebar-pane {
  top: calc(var(--sl-nav-height) + var(--sl-banner-height)) !important;
}
body:has(> .site-banner) .main-frame {
  padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height) + var(--sl-banner-height)) !important;
}
body:has(> .site-banner) .right-sidebar {
  padding-top: calc(var(--sl-nav-height) + var(--sl-banner-height)) !important;
}
body:has(> .site-banner) mobile-starlight-toc nav {
  top: calc(var(--sl-nav-height) + var(--sl-banner-height) - 1px) !important;
}
body:has(> .site-banner) {
  scroll-padding-top: calc(1.5rem + var(--sl-nav-height) + var(--sl-mobile-toc-height) + var(--sl-banner-height)) !important;
}
@media (min-width: 72em) {
  body:has(> .site-banner) {
    scroll-padding-top: calc(1.5rem + var(--sl-nav-height) + var(--sl-banner-height)) !important;
  }
}
</style>

{
slug === '' || slug === curLocale ?
<style>
  .header {
    background-color: transparent;
      -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x));
  }

  @media (min-width: 50rem) {
    header {
      background-color: transparent !important;
    }
  }
  @media (min-width: 50rem) {
    .header {
      padding-inline-end: var(--sl-nav-pad-y);
    }
  }
</style>
: ''
}

<style>
  .desktop {
    display: none;
    align-items: center;
    gap: 1rem;
    padding-inline-end: 1rem;
  }
  @media (min-width: 72rem) {
    .desktop {
      display: flex;
    }
    .mobile {
      display: none;
    }
  }

  a {
    color: var(--sl-color-white);
    font-weight: 600;
    text-decoration: none;
  }

  /* From https://github.com/withastro/starlight/blob/main/packages/starlight/components/Select.astro */
  label {
    --sl-label-icon-size: 0.875rem;
    --sl-caret-size: 1.25rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--sl-color-gray-1);
  }

  label:hover {
    color: var(--sl-color-gray-2);
  }

  .icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .label-icon {
    font-size: var(--sl-label-icon-size);
    inset-inline-start: 0;
  }

  .caret {
    font-size: var(--sl-caret-size);
    inset-inline-end: 0;
  }

  select {
    border: 0;
    padding-block: 0.625rem;
    padding-inline: calc(var(--sl-label-icon-size) + 0.25rem) calc(var(--sl-caret-size) + 0.25rem);
    width: var(--sl-select-width);
    background-color: transparent;
    text-overflow: ellipsis;
    color: inherit;
    cursor: pointer;
    appearance: none;
  }

  option {
    background-color: var(--sl-color-bg-nav);
    color: var(--sl-color-gray-1);
  }

  @media (min-width: 50rem) {
    select {
      font-size: var(--sl-text-sm);
    }
  }
</style>

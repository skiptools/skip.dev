---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import GalleryCard from '../components/GalleryCard.astro';

const allApps = await getCollection('gallery');

// Average of the App Store and Play Store star ratings. Apps missing one side
// fall back to whichever is present; apps missing both score 0 (used only as a
// tiebreaker when downloads are equal).
function avgStars(app) {
  const a = app.data.ratings?.appStore?.score;
  const p = app.data.ratings?.playStore?.score;
  const vals = [a, p].filter((v) => typeof v === 'number');
  if (vals.length === 0) return 0;
  return vals.reduce((s, v) => s + v, 0) / vals.length;
}

// Natural order: Play Store download floor desc, then average star rating desc,
// then name (final stable tiebreaker so the order is deterministic).
const natural = allApps.slice().sort((a, b) => {
  const da = a.data.ratings?.playStore?.downloads ?? 0;
  const db = b.data.ratings?.playStore?.downloads ?? 0;
  if (db !== da) return db - da;
  const sa = avgStars(a), sb = avgStars(b);
  if (sb !== sa) return sb - sa;
  return a.data.name.localeCompare(b.data.name);
});

// Apply explicit `rank` overrides: split out ranked apps, then re-insert each
// at its 1-indexed slot (lowest rank first so multiple overrides compose).
const ranked = natural.filter((a) => typeof a.data.rank === 'number')
  .sort((a, b) => a.data.rank - b.data.rank);
const apps = natural.filter((a) => typeof a.data.rank !== 'number');
for (const app of ranked) {
  const slot = Math.min(Math.max(app.data.rank - 1, 0), apps.length);
  apps.splice(slot, 0, app);
}

const total = apps.length;
---

<StarlightPage frontmatter={{
  title: 'Apps Built with Skip',
  description: 'Apps in the Apple App Store and Google Play Store built with Skip',
  tableOfContents: false,
  template: 'splash',
}}>
  <section class="gallery-hero">
    <p class="gallery-hero-tagline">
    <small>A small selection of Skip-built cross-platform iOS and Android apps that
        ship from a single Swift codebase.</small>
    </p>
  </section>

  <section class="gallery-grid">
    {apps.map((app) => <GalleryCard app={app} />)}
  </section>

  <section class="gallery-cta">
    <h2>Built something with Skip?</h2>
    <p>
      We'd love to feature your app here.
      <a href="https://github.com/skiptools/skip.dev/issues/new?template=suggest-app.yml" target="_blank" rel="noopener">Open a "Suggest an app" issue on GitHub</a>
      with a link to your App Store and Play Store listings, and we'll add it to the gallery.
    </p>
  </section>
</StarlightPage>

<style>
  /* Restyle the splash-template page H1 with a gradient */
  :global(h1#_top) {
    text-align: center;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--sl-color-accent-high), var(--sl-color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem !important;
  }

  /* Hero */
  .gallery-hero {
    margin: 0 auto 3rem;
    max-width: 720px;
    text-align: center;
  }

  .gallery-hero-tagline {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0;
  }

  :root[data-theme='light'] .gallery-hero-tagline {
    color: var(--sl-color-gray-3);
  }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    margin: 0 0 4rem;
  }

  @media (min-width: 1100px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 0.875rem;
    }
  }

  /* Card */
  :global(.gallery-card) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.75rem 1.25rem 1.5rem;
    border-radius: 1rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    text-decoration: none !important;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    gap: 0.75rem;
    height: 100%;
  }

  :global(.gallery-card:hover) {
    transform: translateY(-4px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.30);
    border-color: var(--sl-color-accent);
  }

  :root[data-theme='light'] :global(.gallery-card:hover) {
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.10);
  }

  :global(.gallery-card-iconwrap) {
    margin-bottom: 0.25rem;
  }

  :global(.gallery-card-icon) {
    width: 96px;
    height: 96px;
    border-radius: 22%;
    object-fit: cover;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 12px 24px rgba(0, 0, 0, 0.25),
      0 4px 8px rgba(0, 0, 0, 0.10);
    transition: transform 0.25s ease;
  }

  :root[data-theme='light'] :global(.gallery-card-icon) {
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.05),
      0 12px 24px rgba(0, 0, 0, 0.10),
      0 4px 8px rgba(0, 0, 0, 0.06);
  }

  :global(.gallery-card:hover .gallery-card-icon) {
    transform: scale(1.04);
  }

  :global(.gallery-card-icon-placeholder) {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--sl-color-accent), var(--sl-color-accent-low));
    color: var(--sl-color-white);
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* Name */
  :global(.gallery-card-name) {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--sl-color-white);
    letter-spacing: -0.01em;
  }

  /* Tagline */
  :global(.gallery-card-tagline) {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--sl-color-gray-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  :root[data-theme='light'] :global(.gallery-card-tagline) {
    color: var(--sl-color-gray-3);
  }

  /* CTA */
  .gallery-cta {
    margin: 4rem 0 2rem;
    padding: 2.25rem 1.5rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(0, 113, 167, 0.08), transparent 70%), var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    text-align: center;
  }

  .gallery-cta h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
    color: var(--sl-color-white);
  }

  .gallery-cta p {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 1rem;
    line-height: 1.6;
  }

  :root[data-theme='light'] .gallery-cta p {
    color: var(--sl-color-gray-3);
  }
</style>
